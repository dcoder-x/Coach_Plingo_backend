        {
          "name": "Reset Path",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/learning/paths/{{learning_path_id}}/reset"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Path reset succeeded', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const newPathId = json?.data?.path?.id || '';",
                  "if (newPathId) {",
                  "  pm.collectionVariables.set('previous_learning_path_id', pm.collectionVariables.get('learning_path_id') || '');",
                  "  pm.collectionVariables.set('learning_path_id', newPathId);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Delete Active Path",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/learning/paths/{{learning_path_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Path deletion succeeded', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Logout endpoint responded', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const envLanguage = pm.environment.get('language');",
          "if (!pm.collectionVariables.get('target_language') && envLanguage) {",
          "  pm.collectionVariables.set('target_language', envLanguage);",
          "}"
        ]
      }
    }
