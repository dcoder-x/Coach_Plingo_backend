{
  "info": {
    "_postman_id": "coach-plingo-v3-e2e",
    "name": "Coach Plingo V3 Backend E2E",
    "description": "Detailed end-to-end collection for V3-only backend flow: catalog discovery, auth, learning path lifecycle, scenario session completion, retake, and cleanup.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Preflight",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health",
            "description": "Checks backend availability before executing authenticated E2E flow."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health endpoint is reachable', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Health payload has status ok', function () {",
                  "  pm.expect(json.status).to.equal('ok');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "02 - Catalog Bootstrap",
      "item": [
        {
          "name": "List Professions",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/catalog/professions",
            "description": "Gets profession catalog and stores a profession id + slug for path creation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Professions loaded', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const professions = json?.data?.professions || [];",
                  "pm.test('At least one profession exists', function () {",
                  "  pm.expect(professions.length).to.be.above(0);",
                  "});",
                  "",
                  "const first = professions[0] || {};",
                  "const professionId = first.id || '';",
                  "const professionSlug = first.slug || first.profession || first.name || '';",
                  "",
                  "if (professionId) pm.collectionVariables.set('profession_id', professionId);",
                  "if (professionSlug) pm.collectionVariables.set('profession_slug', professionSlug);"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Profession Subcategories",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/catalog/professions/{{profession_id}}/subcategories",
            "description": "Fetches subcategories and stores the first subcategory id for path creation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Subcategories loaded', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const subcategories = json?.data?.subcategories || [];",
                  "pm.test('At least one subcategory exists', function () {",
                  "  pm.expect(subcategories.length).to.be.above(0);",
                  "});",
                  "",
                  "const first = subcategories[0] || {};",
                  "if (first.id) pm.collectionVariables.set('subcategory_id', first.id);",
                  "const professionSlugFromSubcategoryCall = json?.data?.profession;",
                  "if (professionSlugFromSubcategoryCall) pm.collectionVariables.set('profession_slug', professionSlugFromSubcategoryCall);"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "List Languages",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/catalog/languages",
            "description": "Ensures language catalog endpoint is healthy. Uses existing {{language}} variable for path creation by default."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Languages loaded', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const languages = json?.data?.languages || [];",
                  "pm.test('At least one language exists', function () {",
                  "  pm.expect(languages.length).to.be.above(0);",
                  "});",
                  "",
                  "const selected = pm.collectionVariables.get('language') || pm.environment.get('language') || '';",
                  "if (selected) pm.collectionVariables.set('target_language', selected);"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "03 - Auth",
      "item": [
        {
          "name": "Sign Up Random Learner",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const stamp = Date.now();",
                  "const email = `e2e.v3.${stamp}@coachplingo.test`;",
                  "const password = `SecurePass${stamp % 100000}A1`;",
                  "pm.collectionVariables.set('e2e_email', email);",
                  "pm.collectionVariables.set('e2e_password', password);",
                  "pm.collectionVariables.set('e2e_full_name', 'E2E V3 Learner');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Signup succeeded', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const data = json?.data || {};",
                  "const learner = data?.learner || {};",
                  "const token = data?.token || {};",
                  "if (learner?.id) pm.collectionVariables.set('learner_id', learner.id);",
                  "if (token?.accessToken) pm.collectionVariables.set('access_token', token.accessToken);",
                  "if (token?.refreshToken) pm.collectionVariables.set('refresh_token', token.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{e2e_email}}\",\n  \"password\": \"{{e2e_password}}\",\n  \"fullName\": \"{{e2e_full_name}}\"\n}"
            },
            "url": "{{base_url}}/auth/signup"
          },
          "response": []
        },
        {
          "name": "Login Learner",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{e2e_email}}\",\n  \"password\": \"{{e2e_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const data = json?.data || {};",
                  "const learner = data?.learner || {};",
                  "const token = data?.token || {};",
                  "pm.test('Access token returned', function () {",
                  "  pm.expect(token?.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "if (learner?.id) pm.collectionVariables.set('learner_id', learner.id);",
                  "if (token?.accessToken) pm.collectionVariables.set('access_token', token.accessToken);",
                  "if (token?.refreshToken) pm.collectionVariables.set('refresh_token', token.refreshToken);"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Auth Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Auth profile fetched', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const id = json?.data?.learner?.id || json?.data?.id;",
                  "if (id) pm.collectionVariables.set('learner_id', id);"
                ]
              }
            }
          ],
          "response": []
        }
      ]
