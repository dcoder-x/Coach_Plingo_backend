    {
      "name": "05 - Scenario Session",
      "item": [
        {
          "name": "Get Current Scenario Session",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/learning/paths/{{learning_path_id}}/current-scenario-session",
            "description": "Retrieves active scenario session. If content is still preparing, the collection auto-retries this request up to 5 times when using the runner/newman."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Scenario session endpoint responded', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const data = json?.data || {};",
                  "",
                  "if (data?.ready === false) {",
                  "  const current = Number(pm.collectionVariables.get('session_retry_count') || 0) + 1;",
                  "  pm.collectionVariables.set('session_retry_count', String(current));",
                  "  if (current <= 5) {",
                  "    postman.setNextRequest('Get Current Scenario Session');",
                  "    return;",
                  "  }",
                  "  pm.test('Session became ready within retry limit', function () {",
                  "    pm.expect.fail('Scenario session still PREPARING after 5 retries');",
                  "  });",
                  "  return;",
                  "}",
                  "",
                  "pm.collectionVariables.set('session_retry_count', '0');",
                  "const lessonId = data?.lessonId || data?.lesson_id || '';",
                  "const words = data?.words || [];",
                  "const comprehensionBlocks = data?.comprehension || [];",
                  "const wordResults = words.map((w) => ({",
                  "  wordId: w.id,",
                  "  pronunciationScore: 95,",
                  "  fillGapCorrect: true,",
                  "  attemptCount: 1",
                  "}));",
                  "",
                  "const comprehensionResponses = [];",
                  "for (const block of comprehensionBlocks) {",
                  "  for (const q of (block?.questions || [])) {",
                  "    let response = 'sample answer';",
                  "    if (q?.questionType === 'multiple_choice' && Array.isArray(q?.options) && q.options.length > 0) {",
                  "      response = String(q.options[0]);",
                  "    }",
                  "    comprehensionResponses.push({",
                  "      questionId: q.questionId,",
                  "      response",
                  "    });",
                  "  }",
                  "}",
                  "",
                  "pm.test('Session has lesson id', function () {",
                  "  pm.expect(lessonId).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('Session has at least one word', function () {",
                  "  pm.expect(wordResults.length).to.be.above(0);",
                  "});",
                  "",
                  "if (lessonId) pm.collectionVariables.set('lesson_id', lessonId);",
                  "pm.collectionVariables.set('completion_payload', JSON.stringify({",
                  "  lessonType: 'SCENARIO',",
                  "  lessonId,",
                  "  wordResults,",
                  "  comprehensionResponses",
                  "}, null, 2));"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Complete Current Scenario Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{completion_payload}}"
            },
            "url": "{{base_url}}/learning/paths/{{learning_path_id}}/current-scenario-session/complete",
            "description": "Submits payload generated from live session data in the previous request."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Scenario completion accepted', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const data = json?.data || {};",
                  "if (data?.lessonId) pm.collectionVariables.set('completed_lesson_id', data.lessonId);",
                  "if (typeof data?.pathCompleted !== 'undefined') {",
                  "  pm.collectionVariables.set('path_completed', String(data.pathCompleted));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Lessons Map (After Completion)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/learning/paths/{{learning_path_id}}/lessons"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lessons map fetched after completion', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const subcategories = json?.data?.subcategories || [];",
                  "let completedLesson = '';",
                  "for (const sub of subcategories) {",
                  "  for (const lesson of (sub?.lessons || [])) {",
                  "    if (lesson?.status === 'COMPLETED' && lesson?.lessonId) {",
                  "      completedLesson = lesson.lessonId;",
                  "      break;",
                  "    }",
                  "  }",
                  "  if (completedLesson) break;",
                  "}",
                  "if (completedLesson) pm.collectionVariables.set('completed_lesson_id', completedLesson);"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Retake Completed Lesson",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/learning/paths/{{learning_path_id}}/lessons/{{completed_lesson_id}}/retake"
