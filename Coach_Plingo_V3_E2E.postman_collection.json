        {
          "name": "Get Lessons Map (Initial)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/learning/paths/{{learning_path_id}}/lessons"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lessons map fetched', function () {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const subcategories = json?.data?.subcategories || [];",
                  "let firstLessonId = '';",
                  "for (const sub of subcategories) {",
                  "  const lessons = sub?.lessons || [];",
                  "  if (lessons.length > 0 && lessons[0]?.lessonId) {",
                  "    firstLessonId = lessons[0].lessonId;",
                  "    break;",
                  "  }",
                  "}",
                  "if (firstLessonId) pm.collectionVariables.set('lesson_id', firstLessonId);"
                ]
              }
            }
          ],
          "response": []
        }
      ]
