// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 3.1 Identity Domain
// ============================================================================

model Learner {
  id              String   @id @default(cuid())
  fullName        String
  email           String   @unique
  oauthProvider   String?  // 'google' | 'apple' | null for email auth
  oauthId         String?
  baseLanguage    String   // Learner's native language
  profession      String   // Determines vocabulary relevance
  location        String?  // Optional locale/dialect hints
  avatarUrl       String?
  avatarPublicId  String?
  emailVerified   Boolean  @default(false)
  notificationInAppEnabled Boolean @default(true)
  notificationEmailEnabled Boolean @default(true)
  twoFactorEnabled Boolean @default(false)
  twoFactorMethod  String?
  twoFactorCodeHash String?
  twoFactorCodeExpiry DateTime?
  emailOtp        String?
  emailOtpExpiry  DateTime?
  passwordResetOtp       String?
  passwordResetOtpExpiry DateTime?
  profileComplete Boolean  @default(false)
  passwordHash    String?  // null if OAuth user
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pushToken       String?  // Expo push notification token

  // Relations
  learningPaths            LearningPath[]
  comprehensionResponses   ComprehensionResponse[]
  pronunciationAttempts    PronunciationAttempt[]
  streak                   LearnerStreak?
  badges                   LearnerBadge[]
  notifications            Notification[]

  @@index([email])
  @@index([oauthProvider, oauthId])
}

model LanguageOption {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  ttsVoiceId String?  // ElevenLabs voice ID for native-accent TTS; null falls back to ELEVENLABS_VOICE_ID env var
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
  @@index([name])
}

model ProfessionOption {
  id        String   @id @default(cuid())
  slug      String   @unique
  subCategories ProfessionSubcategory[]
  scenarios ProfessionScenario[]
  learningPaths LearningPath[] @relation("PathProfession")
  name      String
  description String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([name])
}

model ProfessionSubcategory {
  id              String   @id @default(cuid())
  professionId    String
  profession      ProfessionOption @relation(fields: [professionId], references: [id], onDelete: Cascade)
  slug            String?
  name            String
  description     String?
  position        Int
  createdAt       DateTime @default(now())

  learningPaths             LearningPath[]
  subcategoryProgressRows   SubcategoryProgress[]
  scenarioLessons           ScenarioLesson[]

  @@unique([professionId, position])
  @@index([professionId, slug])
}

model ProfessionScenario {
  id            String   @id @default(cuid())
  professionId  String
  profession    ProfessionOption @relation(fields: [professionId], references: [id], onDelete: Cascade)
  slug          String
  displayName   String
  description   String?
  position      Int
  createdAt     DateTime @default(now())

  scenarioLessons ScenarioLesson[]
  currentLearningPaths LearningPath[] @relation("CurrentScenarioPath")

  @@unique([professionId, position])
  @@unique([professionId, slug])
}

// ============================================================================
// 3.2 Learning Path Domain
// ============================================================================

model LearningPath {
  id              String   @id @default(cuid())
  learnerId       String
  language        String   // Target language being learned
  profession      String   // Profession context
  professionId    String?
  status          LearningPathStatus @default(ACTIVE) // active | paused | completed | archived
  currentMilestone Int      @default(1) // 1, 2, or 3
  currentSubcategoryId String?
  currentScenarioId String?
  subcategoriesCompleted Int @default(0)
  scenariosCompleted Int @default(0)
  wordsPerLesson  Int      @default(20) // Learner-configured batch size
  pathXp          Int      @default(0)  // Cumulative XP: sum of passRates from first-pass lesson completions
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learner         Learner  @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  professionRef   ProfessionOption? @relation("PathProfession", fields: [professionId], references: [id])
  currentSubcategory ProfessionSubcategory? @relation(fields: [currentSubcategoryId], references: [id])
  currentScenario ProfessionScenario? @relation("CurrentScenarioPath", fields: [currentScenarioId], references: [id])
  milestones      Milestone[]
  learnerWordStates LearnerWordState[]
  subcategoryProgress SubcategoryProgress[]
  scenarioProgress LearnerScenarioProgress[]

  @@index([learnerId])
  @@index([status])
  @@index([currentSubcategoryId])
  @@index([professionId])
  @@index([currentScenarioId])
}

enum LessonStatus {
  DRAFT
  REVIEWED
  PUBLISHED
}

enum ScenarioProgressStatus {
  LOCKED
  ACTIVE
  COMPLETED
}

model ScenarioLesson {
  id               String   @id @default(cuid())
  subcategoryId    String
  subcategory      ProfessionSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  scenarioId       String
  scenario         ProfessionScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  language         String
  scenarioPosition Int
  status           LessonStatus @default(DRAFT)
  generatedAt      DateTime?
  reviewedAt       DateTime?
  publishedAt      DateTime?
  createdAt        DateTime @default(now())

  words            ScenarioWord[]
  comprehensions   ScenarioComprehension[]
  learnerProgress  LearnerScenarioProgress[]

  @@unique([subcategoryId, scenarioId, language])
  @@index([subcategoryId, language, status])
  @@index([subcategoryId, language, scenarioPosition])
}

model ScenarioWord {
  id                String   @id @default(cuid())
  lessonId          String
  lesson            ScenarioLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  word              String
  ipa               String?
  complexityLevel   DifficultyBand
  examplePhrases    Json?
  exampleSentences  Json?
  tags              Json?
  position          Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  translations      WordTranslation[]
  audioCache        WordAudioCache[]
  learnerWordStates LearnerWordState[]
  pronunciationAttempts PronunciationAttempt[]

  @@unique([lessonId, position])
  @@index([lessonId])
  @@index([word])
}

model WordAudioCache {
  id              String   @id @default(cuid())
  wordId          String
  word            ScenarioWord @relation(fields: [wordId], references: [id], onDelete: Cascade)
  language        String
  audioUrl        String
  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([wordId, language])
  @@index([wordId])
}

model ScenarioComprehension {
  id          String   @id @default(cuid())
  lessonId    String
  lesson      ScenarioLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  content     String
  contentTranslation String?
  audioUrl    String?
  tokenGlosses Json?    // Array of {token: string, start: number, end: number, lemma?: string, baseLanguageGloss: string, source: string}
  position    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   ComprehensionQuestion[]

  @@index([lessonId])
  @@index([position])
}

model LearnerScenarioProgress {
  id                  String   @id @default(cuid())
  learningPathId      String
  learningPath        LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  lessonId            String
  lesson              ScenarioLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status              ScenarioProgressStatus @default(LOCKED)
  wordsCompleted      Int      @default(0)
  comprehensionPassed Boolean  @default(false)
  comprehensionScore  Decimal? @db.Decimal(4, 2)
  timesCompleted      Int      @default(0)
  bestCompScore       Decimal? @db.Decimal(4, 2)
  wordMasteryLevel    Decimal  @default(0.00) @db.Decimal(5, 2) // 0-100, % of lesson words with mastered = true
  lessonMastered      Boolean  @default(false)                   // true when wordMasteryLevel >= 70
  startedAt           DateTime?
  completedAt         DateTime?
  lastCompletedAt     DateTime?
  unlockedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([learningPathId, lessonId])
  @@index([learningPathId, status])
}

enum LearningPathStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model SubcategoryProgress {
  id                   String   @id @default(cuid())
  learningPathId       String
  subcategoryId        String
  status               SubcategoryStatus @default(PENDING)
  wordsCompleted       Int      @default(0)
  wordsTotal           Int      @default(0)
  milestonesCompleted  Int      @default(0)
  unlockedAt           DateTime?
  completedAt          DateTime?

  learningPath         LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  subcategory          ProfessionSubcategory @relation(fields: [subcategoryId], references: [id])

  @@unique([learningPathId, subcategoryId])
  @@index([learningPathId, status])
}

enum SubcategoryStatus {
  PENDING
  ACTIVE
  COMPLETED
}

model LearnerStreak {
  id               String   @id @default(cuid())
  learnerId        String   @unique
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastActivityDate DateTime? @db.Date
  streakAtRisk     Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  learner          Learner  @relation(fields: [learnerId], references: [id], onDelete: Cascade)
}

model Milestone {
  id              String   @id @default(cuid())
  learningPathId  String
  milestoneNumber Int      // 1 = vocabulary sprint, 2 = comprehension, 3 = pronunciation mastery
  type            MilestoneType
  status          MilestoneStatus @default(PENDING)
  generatedWords  Json?    // Milestone 1 only - accumulated words to prevent duplicates
  unlockedAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learningPath    LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  stories         Story[]
  pronunciationExercises PronunciationExercise[]

  @@unique([learningPathId, milestoneNumber])
  @@index([learningPathId])
  @@index([status])
}

enum MilestoneType {
  VOCABULARY_SPRINT
  COMPREHENSION
  PRONUNCIATION_MASTERY
}

enum MilestoneStatus {
  PENDING
  ACTIVE
  COMPLETED
}

// ============================================================================
// 3.3 Vocabulary Domain
// ============================================================================

model GlobalVocabularySet {
  id              String   @id @default(cuid())
  language        String   // Target language
  profession      String   // Profession context
  difficultyBand  DifficultyBand
  wordCount       Int      @default(0)
  lastGeneratedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  words           GlobalVocabularyWord[]

  @@unique([language, profession, difficultyBand])
  @@index([language, profession])
}

enum DifficultyBand {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model GlobalVocabularyWord {
  id                String   @id @default(cuid())
  setId             String
  word              String   // Target-language word
  complexityLevel   DifficultyBand
  examplePhrases    Json?    // Array of phrases
  exampleSentences  Json?    // Array of sentences
  tags              Json?    // Semantic tags for targeting
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  vocabularySet     GlobalVocabularySet @relation(fields: [setId], references: [id], onDelete: Cascade)
  translations      WordTranslation[]
  audioCache        VocabularyAudioCache?
  learnerWordStates LearnerWordState[]

  @@index([setId])
  @@index([complexityLevel])
  @@index([word])
}

model WordTranslation {
  id              String   @id @default(cuid())
  wordId          String?
  scenarioWordId  String?
  baseLanguage    String   // Learner's native language
  translation     String
  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  word            GlobalVocabularyWord? @relation(fields: [wordId], references: [id], onDelete: Cascade)
  scenarioWord    ScenarioWord? @relation(fields: [scenarioWordId], references: [id], onDelete: Cascade)

  @@unique([wordId, baseLanguage])
  @@unique([scenarioWordId, baseLanguage])
  @@index([wordId])
  @@index([scenarioWordId])
  @@index([baseLanguage])
}

model VocabularyAudioCache {
  id              String   @id @default(cuid())
  wordId          String   @unique
  language        String   // Target language (for disambiguation)
  audioUrl        String   // Object store URL - permanent
  ipa             String?  // IPA transcription
  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  word            GlobalVocabularyWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([wordId])
}

model CommonWordGloss {
  id                  String   @id @default(cuid())
  language            String   // Target language
  token               String   // High-frequency word: "the", "and", "en", "y"
  lemma               String?  // Canonical form
  baseLanguageGloss   String   // Brief translation in learner's native language (optional, usually English)
  partOfSpeech        String?  // Optional: noun, verb, pronoun, article, conjunction, preposition
  frequencyRank       Int?     // 1-100 ranking; 1 = most common. Used for quality filtering
  source              String   @default("common_lexicon") // "common_lexicon" | "lesson_vocab"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([language, token])
  @@index([language])
  @@index([frequencyRank])
}

// ============================================================================
// 3.4 Active Learning Window
// ============================================================================

model LearnerWordState {
  id                String   @id @default(cuid())
  learningPathId    String
  wordId            String?
  scenarioWordId    String?
  status            WordStatus @default(LOCKED)
  masteryScore      Decimal  @default(0.00) @db.Decimal(4, 2) // 0.00-10.00, threshold 8.0
  meaningSeen       Boolean  @default(false)
  usageCompleted    Boolean  @default(false)
  fillGapCompleted  Boolean  @default(false)
  pronunciationPassed Boolean @default(false)
  mastered          Boolean  @default(false)
  pronunciationScore Decimal  @default(0.00) @db.Decimal(4, 2)
  attemptCount      Int      @default(0)
  lastAttemptedAt   DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  learningPath      LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  word              GlobalVocabularyWord? @relation(fields: [wordId], references: [id], onDelete: Cascade)
  scenarioWord      ScenarioWord? @relation(fields: [scenarioWordId], references: [id], onDelete: Cascade)

  @@unique([learningPathId, wordId])
  @@unique([learningPathId, scenarioWordId])
  @@index([learningPathId])
  @@index([wordId])
  @@index([scenarioWordId])
  @@index([status])
  @@index([masteryScore])
}

enum WordStatus {
  ACTIVE
  LOCKED
  MASTERED
}

// ============================================================================
// 3.5 Comprehension Domain
// ============================================================================

model Story {
  id                String   @id @default(cuid())
  milestoneId       String
  content           String   // Full story text
  vocabularyCoverage Json?   // Array of word IDs embedded in story
  status            StoryStatus @default(GENERATED)
  generatedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  milestone         Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  questions         ComprehensionQuestion[]

  @@unique([milestoneId])
  @@index([milestoneId])
}

enum StoryStatus {
  GENERATED
  PUBLISHED
}

model ComprehensionQuestion {
  id              String   @id @default(cuid())
  storyId         String?
  comprehensionId String?
  questionText    String
  questionTranslation String?
  options         Json?    // Array of MCQ options (null for short-answer)
  optionsTranslation Json?  // Array of translations for MCQ options
  correctAnswer   String
  questionType    QuestionType
  position        Int      // Display order
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  story           Story? @relation(fields: [storyId], references: [id], onDelete: Cascade)
  comprehension   ScenarioComprehension? @relation(fields: [comprehensionId], references: [id], onDelete: Cascade)
  responses       ComprehensionResponse[]

  @@index([storyId])
  @@index([comprehensionId])
  @@index([position])
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
}

model ComprehensionResponse {
  id              String   @id @default(cuid())
  questionId      String
  learnerId       String
  response        String
  isCorrect       Boolean
  respondedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  question        ComprehensionQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  learner         Learner @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([learnerId])
}

// ============================================================================
// 3.6 Pronunciation Domain
// ============================================================================

model PronunciationExercise {
  id                String   @id @default(cuid())
  milestoneId       String
  targetText        String   // Profession-specific sentence to pronounce
  referenceAudioUrl String   // ElevenLabs-generated reference audio
  complexityLevel   DifficultyBand
  position          Int      // Exercise order within milestone
  generatedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  milestone         Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  attempts          PronunciationAttempt[]

  @@index([milestoneId])
  @@index([position])
}

model PronunciationAttempt {
  id                String   @id @default(cuid())
  exerciseId        String?
  wordId            String?
  learnerId         String
  recordedAudioUrl  String   // S3 object store URL
  accuracyScore     Decimal  @default(0.00) @db.Decimal(5, 2) // 0-100 continuous score
  passed            Boolean  @default(false)
  attemptedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  exercise          PronunciationExercise? @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  word              ScenarioWord? @relation(fields: [wordId], references: [id], onDelete: Cascade)
  learner           Learner @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@index([wordId])
  @@index([learnerId])
}

// ============================================================================
// Notifications (future feature)
// ============================================================================

model Notification {
  id              String   @id @default(cuid())
  learnerId       String
  type            NotificationType
  title           String
  message         String
  read            Boolean  @default(false)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learner         Learner  @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@index([learnerId])
  @@index([read])
}

enum NotificationType {
  MILESTONE_COMPLETED
  WORD_MASTERED
  LESSON_AVAILABLE
  DAILY_REMINDER
  ACHIEVEMENT
  BADGE_EARNED
  STREAK_MILESTONE
  PATH_COMPLETED
  ERROR
}

// ============================================================================
// Badges / Achievements
// ============================================================================

model LearnerBadge {
  id         String   @id @default(cuid())
  learnerId  String
  badgeKey   String   // References a key in the BADGE_CATALOG constant
  earnedAt   DateTime @default(now())

  learner    Learner  @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@unique([learnerId, badgeKey])
  @@index([learnerId])
  @@index([earnedAt])
}

// ============================================================================
// Job Queue (for tracking async operations)
// ============================================================================

model AsyncJob {
  id              String   @id @default(cuid())
  type            JobType
  status          JobStatus @default(PENDING)
  learnerId       String?  // Optional: link to learner
  payload         Json     // Job parameters
  result          Json?    // Job result/output
  error           String?  // Error message if failed
  currentRetry    Int      @default(0)
  maxRetries      Int      @default(3)
  attemptedAt     DateTime[]
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([learnerId])
}

enum JobType {
  GENERATE_LESSON
  GENERATE_STORY
  GENERATE_EXERCISES
  GENERATE_SCENARIO_LESSON
  GENERATE_AUDIO
  SCORE_PRONUNCIATION
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}