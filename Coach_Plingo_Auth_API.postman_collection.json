{
  "info": {
    "_postman_id": "coach-plingo-api",
    "name": "Coach Plingo API",
    "description": "Complete API collection for Coach Plingo language learning platform with Auth, Learning Paths, Progress Tracking, Vocabulary, Notifications, and Content Generation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Account Management",
          "item": [
            {
              "name": "Sign Up",
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"fullName\": \"John Doe\"\n}"
                },
                "url": {"raw": "{{base_url}}/auth/signup", "host": ["{{base_url}}"], "path": ["auth", "signup"]},
                "description": "Create a new learner account with email and password"
              }
            },
            {
              "name": "Register (Alias)",
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"newuser2@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"fullName\": \"Jane Smith\"\n}"
                },
                "url": {"raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"]},
                "description": "Alternative signup endpoint"
              }
            },
            {
              "name": "Login",
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
                },
                "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]},
                "description": "Login with email and password. Returns access and refresh tokens."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is successful', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                      "try {",
                      "  const json = pm.response.json();",
                      "  const data = json?.data || {};",
                      "  if (data?.learner?.id) pm.collectionVariables.set('learner_id', data.learner.id);",
                      "  if (data?.token?.accessToken) pm.collectionVariables.set('access_token', data.token.accessToken);",
                      "  if (data?.token?.refreshToken) pm.collectionVariables.set('refresh_token', data.token.refreshToken);",
                      "  if (data?.onboardingToken) pm.collectionVariables.set('onboarding_token', data.onboardingToken);",
                      "  if (data?.nextStep) pm.collectionVariables.set('next_step', data.nextStep);",
                      "} catch (error) {",
                      "  console.log('No JSON body to parse for token capture', error);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Get Current Profile",
              "request": {
                "method": "GET",
                "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
                "url": {"raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"]},
                "description": "Retrieve the current logged-in learner profile"
              }
            },
            {
              "name": "Update Profile",
              "request": {
                "method": "PUT",
                "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"fullName\": \"John Updated\",\n  \"baseLanguage\": \"en\",\n  \"profession\": \"software_engineer\",\n  \"location\": \"Lagos\"\n}"
                },
                "url": {"raw": "{{base_url}}/auth/profile", "host": ["{{base_url}}"], "path": ["auth", "profile"]},
                "description": "Update learner profile information"
              }
            },
            {
              "name": "Change Password",
              "request": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"currentPassword\": \"SecurePass123!\",\n  \"newPassword\": \"NewSecurePass456!\"\n}"
                },
                "url": {"raw": "{{base_url}}/auth/change-password", "host": ["{{base_url}}"], "path": ["auth", "change-password"]},
                "description": "Change account password (requires current password)"
              }
            },
            {
              "name": "Complete Onboarding",
              "request": {
                "method": "POST",
                "header": [{"key": "Authorization", "value": "Bearer {{onboarding_token}}"}],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {"key": "fullName", "value": "John Doe", "type": "text"},
                    {"key": "baseLanguage", "value": "en", "type": "text"},
                    {"key": "profession", "value": "software_engineer", "type": "text"},
                    {"key": "location", "value": "Lagos", "type": "text"},
                    {"key": "avatar", "type": "file", "src": "/path/to/your/image.jpg"}
                  ]
                },
                "url": {"raw": "{{base_url}}/auth/onboarding", "host": ["{{base_url}}"], "path": ["auth", "onboarding"]},
                "description": "Complete profile onboarding using onboarding token. Returns access and refresh tokens."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is successful', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                      "try {",
                      "  const json = pm.response.json();",
                      "  const data = json?.data || {};",
                      "  if (data?.learner?.id) pm.collectionVariables.set('learner_id', data.learner.id);",
                      "  if (data?.token?.accessToken) pm.collectionVariables.set('access_token', data.token.accessToken);",
                      "  if (data?.token?.refreshToken) pm.collectionVariables.set('refresh_token', data.token.refreshToken);",
                      "  if (data?.nextStep) pm.collectionVariables.set('next_step', data.nextStep);",
                      "} catch (error) {",
                      "  console.log('No JSON body to parse for token capture', error);",
                      "}"
                    ]
                  }
                }
              ]
            },
