# Database
DATABASE_URL="postgresql://user:password@localhost:5432/coachplingo_dev"

# Application
NODE_ENV="development"
PORT=3000
WEBHOOK_BASE_URL="http://localhost:3000"

# JWT / Auth
JWT_SECRET="change-this-in-production"
JWT_EXPIRY="7d"
JWT_REFRESH_SECRET="change-this-in-production-too"
JWT_REFRESH_EXPIRY="30d"
ONBOARDING_TOKEN_EXPIRY="30m"
BCRYPT_SALT_ROUNDS=10

# OTP
OTP_SECRET="change-this-in-production"
OTP_TTL_MINUTES=10

# Google OAuth (Passport)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# Upstash QStash
UPSTASH_QSTASH_TOKEN="your_qstash_token"
UPSTASH_QSTASH_CURRENT_SIGNING_KEY="your_qstash_signing_key"

# LLM (OpenRouter / Claude fallback)
OPENROUTER_API_KEY="your_openrouter_api_key"
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_APP_NAME="CoachPlingo"
CLAUDE_API_KEY="your_claude_api_key"
CLAUDE_MODEL="anthropic/claude-3.5-sonnet"

# ElevenLabs
ELEVENLABS_API_KEY="your_elevenlabs_api_key"
ELEVENLABS_VOICE_ID="EXAVITQu4vr4xnSDxMaL"

# Cloudinary (avatars/media)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Email / SMTP
EMAIL_FROM="no-reply@coachplingo.app"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_email_app_password"
